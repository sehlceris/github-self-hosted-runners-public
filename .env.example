RUNNER_SCOPE=org
GITHUB_ORG=your_org_cannot_be_a_personal_account
GITHUB_PAT=ghp_xxxxxxx
RUNNER_NAME=grunner
RUNNER_LABELS=self-hosted,linux,amd64

# GID of /var/run/docker.sock on the host. The runner runs as UID 1001 and
# must share a group with the socket to call docker. Find it with:
#   stat -c '%g' /var/run/docker.sock
DOCKER_GID=
